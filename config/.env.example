# claude-code-telegram environment configuration
#
# The installer writes a live copy of this to /etc/claude-code-telegram.env.
# You can also use this as a reference to run the bot manually:
#   source /etc/claude-code-telegram.env && python3 /opt/claude-code-telegram/claude_telegram_bot.py
#
# DO NOT commit a real .env to git — it contains your bot token.
# .gitignore already excludes .env, .env.local, and config/env.

# ───────────────────────────────────────────────────────────
# REQUIRED
# ───────────────────────────────────────────────────────────

# Bot token from @BotFather. Treat like an SSH private key.
TELEGRAM_BOT_TOKEN=

# The only chat ID the bot will respond to.
# The installer fetches this automatically; or find it at:
#   https://api.telegram.org/bot<TOKEN>/getUpdates  (after DMing your bot)
TELEGRAM_CHAT_ID=

# Absolute path to the directory claude operates in (its cwd).
# Typically your Obsidian vault or a code repo.
VAULT_PATH=/home/user/notes

# ───────────────────────────────────────────────────────────
# SESSION MODE  (choose one)
# ───────────────────────────────────────────────────────────

# threaded  — every message continues the most recent claude session in
#             VAULT_PATH (same as `claude --continue`). Shares context with
#             any terminal claude sessions you run in the same directory.
#
# dedicated — bot uses a fixed session UUID so it never bleeds into your
#             terminal sessions. Requires SESSION_ID to be set.
#
# stateless — each Telegram message is a fully independent claude call.
#             No memory between messages; cheapest in tokens.
SESSION_MODE=threaded

# Required only when SESSION_MODE=dedicated.
# Generate one with: python3 -c "import uuid; print(uuid.uuid4())"
SESSION_ID=

# ───────────────────────────────────────────────────────────
# RESPONSE OPTIONS
# ───────────────────────────────────────────────────────────

# markdown — bold, code blocks, and italic rendered by Telegram (default)
# plain    — raw text; safer when responses contain lots of backticks
RESPONSE_FORMAT=markdown

# Show animated "..." in Telegram while claude is thinking.
# 1 = on (default), 0 = off
TYPING_INDICATOR=1

# ───────────────────────────────────────────────────────────
# TUNING
# ───────────────────────────────────────────────────────────

# Path to the claude binary. Must be a full path for systemd (no PATH lookup).
# Find it with: which claude
CLAUDE_BIN=claude

# Seconds to wait for a claude invocation before killing it.
CLAUDE_TIMEOUT=90

# Max Telegram messages sent per response before offering /more.
MAX_CHUNKS=3

# Characters per Telegram message. Hard ceiling is 4096; leave headroom for
# chunk-counter prefixes.
CHUNK_SIZE=3800

# Seconds to sleep between Telegram long-poll cycles.
POLL_INTERVAL=2

# ───────────────────────────────────────────────────────────
# SECURITY
# ───────────────────────────────────────────────────────────

# safe        — every action goes through plan → /go review (default)
# unrestricted — executes with --dangerously-skip-permissions after /go
# Both modes require the plan/confirm step unless /trust is active.
# See §11 in docs/TROUBLESHOOTING.md for permission mode risks.
PERMISSION_MODE=safe

# Maximum messages that can queue while claude is busy before new ones
# are dropped with a Telegram warning. 0 = unlimited (not recommended).
QUEUE_MAX=100

# Maximum messages a single user can send per minute. Excess messages
# are dropped with a Telegram warning. 0 = disabled.
RATE_LIMIT=10

# Hours before a /trust grant automatically expires.
# /status shows remaining trust time. 0 = no expiry.
TRUST_TTL_HOURS=24
